---
import Container from "@components/Container.astro";

type NarrowMode = "always" | "md" | "never";

type Props = {
  narrow?: NarrowMode;
};

const { narrow = "never" } = Astro.props;

const containerProps =
  narrow === "always"
    ? { size: "3xl" as const }
    : narrow === "never"
      ? { size: "5xl" as const }
      : { size: "3xl" as const, lgSize: "5xl" as const };
---

<div class="pt-24 pb-5">
  <Container {...containerProps}>
    <slot />
  </Container>
</div>

<div class="animate">
  <Container {...containerProps}>
    <hr class="mt-3 mb-6 border-black/20 dark:border-white/20" />
  </Container>
</div>
